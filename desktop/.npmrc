# Flat (npm-style) node_modules instead of pnpm's symlinked .pnpm store.
# electron-builder follows only direct dependency links when collecting files
# for the asar; with the default symlinked layout it omits every transitive
# dependency (e.g. @supabase/* sub-packages), and the packaged app crashes at
# startup with MODULE_NOT_FOUND. A hoisted layout packs the full tree.
node-linker=hoisted
